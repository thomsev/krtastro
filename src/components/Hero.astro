---
import { classNames } from "@/utils/common";

const {
  title,
  subtitle,
  eyebrow = 'Karmøy Rørteknikk',
  cta,
  secondaryCta,
  backgroundImage,
  overlay = 0.55,
  compact = false
} = Astro.props;

const heroStyles = [
  backgroundImage ? `--hero-image: url('${backgroundImage}')` : null,
  `--hero-overlay: ${overlay}`
]
  .filter(Boolean)
  .join('; ');
---
<section class={classNames('page-hero', compact && 'page-hero--compact')}>
  <div class="container">
    <div class={classNames('page-hero-frame', backgroundImage && 'page-hero-frame--image')} style={heroStyles} data-hero>
      <div class="page-hero-content">
        <p class="eyebrow eyebrow--light" data-hero-line>{eyebrow}</p>
        <h1 data-hero-line>{title}</h1>
        {subtitle && <p class="page-hero-lead" data-hero-line>{subtitle}</p>}
        {(cta || secondaryCta) && (
          <div class="hero-actions" data-hero-line>
            {cta && <a class="button button--light" href={cta.href}>{cta.label} <span aria-hidden="true">↗</span></a>}
            {secondaryCta && <a class="text-link text-link--light" href={secondaryCta.href}>{secondaryCta.label} <span aria-hidden="true">→</span></a>}
          </div>
        )}
      </div>
      <div class="page-hero-index" aria-hidden="true">KR<span>—</span>01</div>
    </div>
  </div>
</section>
