---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { animationGears, HoverLottie } from '@/components/Lottie';
import { getPage, getProjects, getSiteSettings } from '@/lib/content';

const page = await getPage('hjem');
const projects = await getProjects();
const site = await getSiteSettings();
const phoneLink = `tel:+47${site.phone.replace(/\s/g, '')}`;

const services = [
  {
    number: '01',
    title: 'VVS, varme og sprinkler',
    description: 'Sanitær, varmesentraler, kjøling og slukkeanlegg – fra prosjektering til kontroll.',
    href: '/sanitaer-vvs',
    className: 'service-card--wide'
  },
  {
    number: '02',
    title: 'Plastsveising',
    description: 'Sertifisert sveising av rørsystemer for krevende tekniske og industrielle miljøer.',
    href: '/plastsveising',
    className: 'service-card--dark'
  },
  {
    number: '03',
    title: 'Gasskontroll',
    description: 'Kontroll og dokumentasjon av gassanlegg som del av den tekniske leveransen.',
    href: '/gass',
    className: ''
  },
  {
    number: '04',
    title: 'Industri og gjenvinning',
    description: 'Driftssikre rør- og prosessløsninger tilpasset produksjon, slitasje og vedlikehold.',
    href: '/gjenvinningsanlegg',
    className: 'service-card--image'
  }
];

const process = [
  ['01', 'Behov og befaring', 'Vi avklarer omfang, rammer og den beste tekniske veien videre.'],
  ['02', 'Tydelig tilbud', 'Du får en konkret leveransebeskrivelse og forutsigbare kostnader.'],
  ['03', 'Faglig utførelse', 'Arbeidet gjennomføres sikkert, effektivt og i dialog med involverte fag.'],
  ['04', 'Kontroll og dokumentasjon', 'Vi kvalitetssikrer leveransen og sørger for ryddig avslutning.']
];
---

<BaseLayout title={page?.title} description={page?.description}>
  <section class="home-hero">
    <div class="container home-hero-grid" data-hero>
      <div class="home-hero-copy">
        <p class="eyebrow" data-hero-line>Rørteknikk for Haugalandet</p>
        <h1 data-hero-line>
          Solid håndverk.<br />
          <span>Teknisk presisjon.</span>
        </h1>
        <p class="home-hero-lead" data-hero-line>
          Vi er teknisk totalentreprenør for VVS, varme, kjøling, sprinkler og industrirør – fra første avklaring til dokumentert resultat.
        </p>
        <div class="hero-actions" data-hero-line>
          <a class="button" href="/kontakt-oss">Be om tilbud <span aria-hidden="true">↗</span></a>
          <a class="text-link" href="/prosjekter">Se prosjekter <span aria-hidden="true">→</span></a>
        </div>
        <div class="hero-proof" data-hero-line>
          <span><i aria-hidden="true"></i> Etablert i {site.established}</span>
          <span><i aria-hidden="true"></i> Sentralt godkjent foretak</span>
        </div>
      </div>
      <div class="home-hero-media">
        <div class="hero-image-wrap">
          <img src="/images/generated/industrial-pipefitter.jpg" alt="Illustrasjon av industrirørlegger i et moderne teknisk anlegg" width="1536" height="1024" fetchpriority="high" data-parallax />
        </div>
        <div class="hero-media-card">
          <span>Bolig</span><b>+</b><span>Næring</span><b>+</b><span>Industri</span>
        </div>
        <div class="hero-mark" aria-hidden="true">KRT</div>
      </div>
    </div>
    <div class="container marquee" aria-label="Våre fagområder">
      <div>
        <span>Sanitær og VVS</span><i></i><span>Varme og kjøling</span><i></i><span>Sprinkler</span><i></i><span>Industrirør</span><i></i><span>Sveising</span>
      </div>
    </div>
  </section>

  <section class="facts-strip" aria-label="Nøkkelfakta om Karmøy Rørteknikk">
    <div class="container facts-grid" data-stagger>
      <div data-stagger-item><strong>{site.established}</strong><span>Etablert</span></div>
      <div data-stagger-item><strong>{site.employeesLabel}</strong><span>Lokalt fagmiljø</span></div>
      <div data-stagger-item><strong>Klasse 3</strong><span>Utførende godkjenning</span></div>
      <div data-stagger-item><strong>Lærebedrift</strong><span>Rørleggerfaget</span></div>
    </div>
  </section>

  <section class="section section--intro">
    <div class="container intro-grid">
      <div data-animate="fade-up">
        <p class="eyebrow">Én partner. Hele leveransen.</p>
        <h2>Vi får rørsystemene til å fungere – i hverdagen og under press.</h2>
      </div>
      <div class="intro-copy" data-animate="fade-left">
        <p>Siden 2008 har Karmøy Rørteknikk utviklet seg til et fagmiljø med rundt 30 medarbeidere og leveranser gjennom hele byggefasen.</p>
        <p>Vi kombinerer lokal tilgjengelighet med kompetansen som kreves i teknisk krevende prosjekter.</p>
        <a class="text-link" href="/om-oss">Bli kjent med oss <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <div class="section-heading" data-animate="fade-up">
        <div><p class="eyebrow">Våre tjenester</p><h2>Fagområder som dekker mer.</h2></div>
        <p>Fra bad og sanitæranlegg til industrielle prosessystemer og sertifisert sveising.</p>
      </div>
      <div class="services-grid" data-stagger>
        {services.map((service) => (
          <a class={`service-card ${service.className}`} href={service.href} data-stagger-item data-tilt>
            {service.className.includes('image') && <img src="/images/generated/technical-plantroom.jpg" alt="Illustrasjon av moderne rørinstallasjon i teknisk anlegg" width="1536" height="1024" loading="lazy" data-image-reveal />}
            <div class="service-card-top"><span>{service.number}</span><i aria-hidden="true">↗</i></div>
            <div><h3>{service.title}</h3><p>{service.description}</p></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section id="systemforstaelse" class="systems-story" data-systems-story aria-labelledby="systems-story-title">
    <div class="systems-stage">
      <div class="systems-background" data-systems-image>
        <img src="/images/generated/technical-plantroom-hq.jpg" alt="Illustrasjon av et moderne teknisk anlegg med varme- og kjølerør" width="1536" height="1024" loading="eager" fetchpriority="high" />
      </div>
      <div class="systems-scrim" aria-hidden="true"></div>
      <div class="systems-grid" data-systems-grid aria-hidden="true"></div>
      <div class="systems-scan" data-systems-scan aria-hidden="true"></div>
      <svg class="systems-schematic" viewBox="0 0 1440 900" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
        <path class="system-path-rail" d="M-80 180 H250 Q320 180 320 250 V380 Q320 450 390 450 H672" />
        <path class="system-path-rail" d="M1520 300 H1090 Q1020 300 1020 370 V380 Q1020 450 950 450 H768" />
        <path class="system-path-rail" d="M720 -80 V402" />
        <path class="system-path-glow" data-system-path-glow d="M-80 180 H250 Q320 180 320 250 V380 Q320 450 390 450 H672" />
        <path class="system-path-glow" data-system-path-glow d="M1520 300 H1090 Q1020 300 1020 370 V380 Q1020 450 950 450 H768" />
        <path class="system-path-glow" data-system-path-glow d="M720 -80 V402" />
        <path class="system-path" data-system-path d="M-80 180 H250 Q320 180 320 250 V380 Q320 450 390 450 H672" />
        <path class="system-path" data-system-path d="M1520 300 H1090 Q1020 300 1020 370 V380 Q1020 450 950 450 H768" />
        <path class="system-path" data-system-path d="M720 -80 V402" />
        <g class="flow-node" data-flow-node transform="translate(-80 180)">
          <circle class="flow-node__pulse" data-flow-pulse r="10" />
          <circle class="flow-node__ring" r="13" />
          <circle class="flow-node__core" r="7" />
        </g>
        <g class="flow-node" data-flow-node transform="translate(1520 300)">
          <circle class="flow-node__pulse" data-flow-pulse r="10" />
          <circle class="flow-node__ring" r="13" />
          <circle class="flow-node__core" r="7" />
        </g>
        <g class="flow-node" data-flow-node transform="translate(720 -80)">
          <circle class="flow-node__pulse" data-flow-pulse r="10" />
          <circle class="flow-node__ring" r="13" />
          <circle class="flow-node__core" r="7" />
        </g>
        <circle class="system-packet" data-system-packet data-route="0" transform="translate(-80 180)" r="3" />
        <circle class="system-packet system-packet--signal" data-system-packet data-route="0" transform="translate(-80 180)" r="2.5" />
        <circle class="system-packet" data-system-packet data-route="1" transform="translate(1520 300)" r="3" />
        <circle class="system-packet system-packet--signal" data-system-packet data-route="1" transform="translate(1520 300)" r="2.5" />
        <circle class="system-packet" data-system-packet data-route="2" transform="translate(720 -80)" r="3" />
        <circle class="system-packet system-packet--signal" data-system-packet data-route="2" transform="translate(720 -80)" r="2.5" />
        <g class="system-hub" data-system-hub transform="translate(720 450)">
          <path class="system-hub__connectors" d="M-48 0 H-18 M48 0 H18 M0 -48 V-18" />
          <circle class="system-hub__wave" data-hub-wave r="28" />
          <circle class="system-hub__orbit system-hub__orbit--outer" data-hub-ring r="38" />
          <circle class="system-hub__orbit system-hub__orbit--inner" data-hub-ring r="28" />
          <circle class="system-hub__core" r="17" />
          <circle class="system-hub__signal" r="5" />
        </g>
      </svg>
      <div class="systems-phase" data-systems-phase aria-hidden="true">
        <span data-phase="0" data-active="true">01&nbsp; Kartlegging</span>
        <span data-phase="1">02&nbsp; Koordinering</span>
        <span data-phase="2">03&nbsp; System online</span>
      </div>
      <div class="container systems-content">
        <div class="systems-heading">
          <p class="eyebrow eyebrow--light">Systemforståelse</p>
          <h2 id="systems-story-title"><span>Alt henger</span><br /><span>sammen.</span></h2>
          <p>De beste tekniske anleggene oppleves enkle. Bak ligger presis prosjektering, koordinering og kontroll.</p>
        </div>
        <div class="systems-hud" data-systems-hud aria-hidden="true">
          <div class="systems-hud-ring">
            <span class="systems-hud-index">KRT<br />08</span>
            <HoverLottie
              animation={animationGears}
              autoplay={true}
              loop={true}
              client:only="react"
              containerProps={{ className: 'systems-lottie' }}
            />
          </div>
          <p>Teknisk koordinering</p>
        </div>
        <div class="system-label system-label--heat" data-system-label aria-hidden="true"><i></i><span>Varmekrets</span><b><span data-telemetry="temperature">18</span>°</b></div>
        <div class="system-label system-label--flow" data-system-label aria-hidden="true"><i></i><span>Systemlast</span><b><span data-telemetry="load">00</span>%</b></div>
        <div class="system-label system-label--safe" data-system-label aria-hidden="true"><i></i><span>Trykk</span><b><span data-telemetry="pressure">0.8</span> BAR</b></div>
        <div class="systems-points" data-systems-points>
          <article>
            <span>01</span>
            <h3>Energi i balanse</h3>
            <p>Varme, kjøling og vannbalansering dimensjonert som ett system.</p>
          </article>
          <article>
            <span>02</span>
            <h3>Sikkerhet bygget inn</h3>
            <p>Sprinkler, kontroll og dokumentasjon integrert i leveransen.</p>
          </article>
          <article>
            <span>03</span>
            <h3>Drift som varer</h3>
            <p>Tilgjengelige komponenter og løsninger som er enkle å vedlikeholde.</p>
          </article>
        </div>
        <div class="systems-progress" aria-hidden="true"><span data-systems-progress></span></div>
        <div class="systems-coordinate" aria-hidden="true">59.28° N&nbsp;&nbsp; / &nbsp;&nbsp;5.30° E</div>
      </div>
      <div class="systems-payoff" data-systems-payoff aria-hidden="true">
        <span><i></i> System online</span>
        <strong>Prosjektert som<br />ett system.</strong>
        <p>Levert med kontroll.</p>
      </div>
      <div class="systems-wipe" data-systems-wipe aria-hidden="true"></div>
      {projects[0] && (
        <div class="systems-next" data-systems-next aria-hidden="true">
          <div class="container systems-next__grid">
            <div class="systems-next__copy">
              <p class="eyebrow">Neste / utvalgt arbeid</p>
              <strong>{projects[0].title}</strong>
              <span>{projects[0].location}&nbsp;&nbsp; 01</span>
            </div>
            <div class="systems-next__media">
              <img src={projects[0].image} alt="" width="1536" height="1024" loading="lazy" />
            </div>
          </div>
        </div>
      )}
    </div>
  </section>

  <section class="section projects-section" data-projects-section>
    <div class="container">
      <div class="section-heading" data-animate="fade-up">
        <div><p class="eyebrow">Utvalgt arbeid</p><h2>Prosjekter med tydelig verdi.</h2></div>
        <a class="text-link" href="/prosjekter">Se alle prosjekter <span aria-hidden="true">→</span></a>
      </div>
      <div class="project-grid" data-stagger>
        {projects.map((project, index) => (
          <article class={`project-card ${index === 0 ? 'project-card--featured' : ''}`} data-stagger-item>
            <div class="project-image">
              <img src={project.image} alt={`Illustrasjon for ${project.title}`} width="1536" height="1024" loading="lazy" data-image-reveal />
              {project.imageNote && <span class="image-note">{project.imageNote}</span>}
            </div>
            <div class="project-meta"><span>{project.location}</span><span>0{index + 1}</span></div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section process-section">
    <div class="container process-grid">
      <div class="process-intro" data-animate="fade-up">
        <p class="eyebrow">Slik jobber vi</p>
        <h2>En ryddig prosess fra start til slutt.</h2>
        <p>Du skal vite hva som skjer, hvem som har ansvaret og hva som blir levert.</p>
        <a href={phoneLink} class="text-link">Ring {site.phone} <span aria-hidden="true">→</span></a>
      </div>
      <ol class="process-list" data-stagger>
        {process.map(([number, title, description]) => (
          <li data-stagger-item><span>{number}</span><div><h3>{title}</h3><p>{description}</p></div></li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section final-cta-section">
    <div class="container final-cta" data-animate="fade-up">
      <div>
        <p class="eyebrow eyebrow--light">Har du et prosjekt på gang?</p>
        <h2>Fortell oss hva du trenger.</h2>
      </div>
      <div>
        <p>Vi tar en konkret prat om behov, muligheter og neste steg.</p>
        <div class="hero-actions"><a class="button button--light" href="/kontakt-oss">Send forespørsel <span aria-hidden="true">↗</span></a><a class="text-link text-link--light" href={phoneLink}>Ring oss</a></div>
      </div>
    </div>
  </section>
</BaseLayout>
