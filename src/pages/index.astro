---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { animationGears, HoverLottie } from '@/components/Lottie';
import { getPage, getProjects, getSiteSettings } from '@/lib/content';

const page = await getPage('hjem');
const projects = await getProjects();
const site = await getSiteSettings();
const phoneLink = `tel:+47${site.phone.replace(/\s/g, '')}`;

const services = [
  {
    number: '01',
    title: 'VVS, varme og sprinkler',
    description: 'Sanitær, varmesentraler, kjøling og slukkeanlegg – fra prosjektering til kontroll.',
    href: '/sanitaer-vvs',
    className: 'service-card--wide'
  },
  {
    number: '02',
    title: 'Plastsveising',
    description: 'Sertifisert sveising av rørsystemer for krevende tekniske og industrielle miljøer.',
    href: '/plastsveising',
    className: 'service-card--dark'
  },
  {
    number: '03',
    title: 'Gasskontroll',
    description: 'Kontroll og dokumentasjon av gassanlegg som del av den tekniske leveransen.',
    href: '/gass',
    className: ''
  },
  {
    number: '04',
    title: 'Industri og gjenvinning',
    description: 'Driftssikre rør- og prosessløsninger tilpasset produksjon, slitasje og vedlikehold.',
    href: '/gjenvinningsanlegg',
    className: 'service-card--image'
  }
];

const process = [
  ['01', 'Behov og befaring', 'Vi avklarer omfang, rammer og den beste tekniske veien videre.'],
  ['02', 'Tydelig tilbud', 'Du får en konkret leveransebeskrivelse og forutsigbare kostnader.'],
  ['03', 'Faglig utførelse', 'Arbeidet gjennomføres sikkert, effektivt og i dialog med involverte fag.'],
  ['04', 'Kontroll og dokumentasjon', 'Vi kvalitetssikrer leveransen og sørger for ryddig avslutning.']
];
---

<BaseLayout title={page?.title} description={page?.description}>
  <section class="home-hero">
    <div class="container home-hero-grid" data-hero>
      <div class="home-hero-copy">
        <p class="eyebrow" data-hero-line>Rørteknikk for Haugalandet</p>
        <h1 data-hero-line>
          Solid håndverk.<br />
          <span>Teknisk presisjon.</span>
        </h1>
        <p class="home-hero-lead" data-hero-line>
          Vi er teknisk totalentreprenør for VVS, varme, kjøling, sprinkler og industrirør – fra første avklaring til dokumentert resultat.
        </p>
        <div class="hero-actions" data-hero-line>
          <a class="button" href="/kontakt-oss">Be om tilbud <span aria-hidden="true">↗</span></a>
          <a class="text-link" href="/prosjekter">Se prosjekter <span aria-hidden="true">→</span></a>
        </div>
        <div class="hero-proof" data-hero-line>
          <span><i aria-hidden="true"></i> Etablert i {site.established}</span>
          <span><i aria-hidden="true"></i> Sentralt godkjent foretak</span>
        </div>
      </div>
      <div class="home-hero-media" data-hero-line>
        <div class="hero-image-wrap">
          <img src="/images/generated/industrial-pipefitter.jpg" alt="Illustrasjon av industrirørlegger i et moderne teknisk anlegg" width="1536" height="1024" fetchpriority="high" data-parallax />
        </div>
        <div class="hero-media-card">
          <span>Bolig</span><b>+</b><span>Næring</span><b>+</b><span>Industri</span>
        </div>
        <div class="hero-mark" aria-hidden="true">KRT</div>
      </div>
    </div>
    <div class="container marquee" aria-label="Våre fagområder">
      <div>
        <span>Sanitær og VVS</span><i></i><span>Varme og kjøling</span><i></i><span>Sprinkler</span><i></i><span>Industrirør</span><i></i><span>Sveising</span>
      </div>
    </div>
  </section>

  <section class="facts-strip" aria-label="Nøkkelfakta om Karmøy Rørteknikk">
    <div class="container facts-grid" data-stagger>
      <div data-stagger-item><strong>{site.established}</strong><span>Etablert</span></div>
      <div data-stagger-item><strong>{site.employeesLabel}</strong><span>Lokalt fagmiljø</span></div>
      <div data-stagger-item><strong>Klasse 3</strong><span>Utførende godkjenning</span></div>
      <div data-stagger-item><strong>Lærebedrift</strong><span>Rørleggerfaget</span></div>
    </div>
  </section>

  <section class="section section--intro">
    <div class="container intro-grid">
      <div data-animate="fade-up">
        <p class="eyebrow">Én partner. Hele leveransen.</p>
        <h2>Vi får rørsystemene til å fungere – i hverdagen og under press.</h2>
      </div>
      <div class="intro-copy" data-animate="fade-left">
        <p>Siden 2008 har Karmøy Rørteknikk utviklet seg til et fagmiljø med rundt 30 medarbeidere og leveranser gjennom hele byggefasen.</p>
        <p>Vi kombinerer lokal tilgjengelighet med kompetansen som kreves i teknisk krevende prosjekter.</p>
        <a class="text-link" href="/om-oss">Bli kjent med oss <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="section services-section">
    <div class="container">
      <div class="section-heading" data-animate="fade-up">
        <div><p class="eyebrow">Våre tjenester</p><h2>Fagområder som dekker mer.</h2></div>
        <p>Fra bad og sanitæranlegg til industrielle prosessystemer og sertifisert sveising.</p>
      </div>
      <div class="services-grid" data-stagger>
        {services.map((service) => (
          <a class={`service-card ${service.className}`} href={service.href} data-stagger-item data-tilt>
            {service.className.includes('image') && <img src="/images/generated/technical-plantroom.jpg" alt="Illustrasjon av moderne rørinstallasjon i teknisk anlegg" width="1536" height="1024" loading="lazy" />}
            <div class="service-card-top"><span>{service.number}</span><i aria-hidden="true">↗</i></div>
            <div><h3>{service.title}</h3><p>{service.description}</p></div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section expertise-section">
    <div class="container expertise-grid">
      <div class="expertise-visual" data-animate="fade-up">
        <div class="orbit orbit--one" aria-hidden="true"></div>
        <div class="orbit orbit--two" aria-hidden="true"></div>
        <HoverLottie
          animation={animationGears}
          autoplay={true}
          loop={true}
          client:only="react"
          containerProps={{ className: 'expertise-lottie' }}
        />
        <p>Planlegging <span>→</span> utførelse <span>→</span> dokumentasjon</p>
      </div>
      <div class="expertise-copy" data-animate="fade-left">
        <p class="eyebrow eyebrow--light">Teknisk kompetanse</p>
        <h2>Detaljene avgjør om løsningen varer.</h2>
        <p>God rørteknikk handler om mer enn montasje. Prosjektering, materialvalg, koordinering, sveiseprosedyrer og dokumentasjon må spille sammen.</p>
        <ul class="check-list">
          <li><span>01</span>Prosjektering i tiltaksklasse 2</li>
          <li><span>02</span>Utførelse i tiltaksklasse 3</li>
          <li><span>03</span>Godkjent lærebedrift i rørleggerfaget</li>
        </ul>
        <a class="button button--light" href="/kontakt-oss">Diskuter en løsning <span aria-hidden="true">↗</span></a>
      </div>
    </div>
  </section>

  <section class="section projects-section">
    <div class="container">
      <div class="section-heading" data-animate="fade-up">
        <div><p class="eyebrow">Utvalgt arbeid</p><h2>Prosjekter med tydelig verdi.</h2></div>
        <a class="text-link" href="/prosjekter">Se alle prosjekter <span aria-hidden="true">→</span></a>
      </div>
      <div class="project-grid" data-stagger>
        {projects.map((project, index) => (
          <article class={`project-card ${index === 0 ? 'project-card--featured' : ''}`} data-stagger-item>
            <div class="project-image">
              <img src={project.image} alt={`Illustrasjon for ${project.title}`} width="1536" height="1024" loading="lazy" />
              {project.imageNote && <span class="image-note">{project.imageNote}</span>}
            </div>
            <div class="project-meta"><span>{project.location}</span><span>0{index + 1}</span></div>
            <h3>{project.title}</h3>
            <p>{project.description}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section process-section">
    <div class="container process-grid">
      <div class="process-intro" data-animate="fade-up">
        <p class="eyebrow">Slik jobber vi</p>
        <h2>En ryddig prosess fra start til slutt.</h2>
        <p>Du skal vite hva som skjer, hvem som har ansvaret og hva som blir levert.</p>
        <a href={phoneLink} class="text-link">Ring {site.phone} <span aria-hidden="true">→</span></a>
      </div>
      <ol class="process-list" data-stagger>
        {process.map(([number, title, description]) => (
          <li data-stagger-item><span>{number}</span><div><h3>{title}</h3><p>{description}</p></div></li>
        ))}
      </ol>
    </div>
  </section>

  <section class="section final-cta-section">
    <div class="container final-cta" data-animate="fade-up">
      <div>
        <p class="eyebrow eyebrow--light">Har du et prosjekt på gang?</p>
        <h2>Fortell oss hva du trenger.</h2>
      </div>
      <div>
        <p>Vi tar en konkret prat om behov, muligheter og neste steg.</p>
        <div class="hero-actions"><a class="button button--light" href="/kontakt-oss">Send forespørsel <span aria-hidden="true">↗</span></a><a class="text-link text-link--light" href={phoneLink}>Ring oss</a></div>
      </div>
    </div>
  </section>
</BaseLayout>
